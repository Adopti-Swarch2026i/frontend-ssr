# Variables consumidas por frontend-ssr (Next.js 16 standalone). Fuente
# única de verdad para Docker Compose (cargado vía env_file en
# Compose/docker-compose.yml).
#
# Las NEXT_PUBLIC_* se inlinean durante `next build` (deben existir al
# momento del build, no solo al runtime).

# === Firebase Web (cliente) ===
# Obtener de: https://console.firebase.google.com → Project Settings → SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# === API endpoints públicos (cliente, atraviesan el host) ===
NEXT_PUBLIC_PETS_API_URL=http://localhost/api
NEXT_PUBLIC_CHAT_GRAPHQL_URL=http://localhost/api/chat/graphql
NEXT_PUBLIC_CHAT_WS_URL=ws://localhost/api/chat/ws

# === Firebase Admin (servidor) ===
# Obtener de: Project Settings → Service accounts → Generate new private key
# La private key debe incluir los \n literales (Next.js los convierte a saltos reales).
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# === API endpoints internos (servidor, red docker) ===
PETS_API_URL_INTERNAL=http://gateway/api
CHAT_GRAPHQL_URL_INTERNAL=http://gateway/api/chat/graphql

# === Runtime Next.js (modo standalone) ===
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# === Sesion ===
SESSION_COOKIE_NAME=__session
SESSION_DURATION_DAYS=5
# SESSION_CHECK_REVOCATION=false  # opcional: true para revalidar revocation en cada request
# SESSION_COOKIE_SECURE=true      # opcional: forzar Secure flag (auto-detecta vía X-Forwarded-Proto)

# === Modo desarrollo (mock adapters) ===
NEXT_PUBLIC_MOCK_MODE=false
